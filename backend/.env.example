# HireLens backend environment configuration.
# Copy this file to `.env` and adjust as needed. `.env` is gitignored; this
# example file is committed and documents every supported variable.

# Human-readable application name (shown in /health responses and logs).
APP_NAME=HireLens

# Deployment environment: dev | prod
APP_ENV=dev

# URL prefix for all versioned v1 API routes.
API_V1_PREFIX=/api/v1

# CORS allow-list. Comma-separated list of allowed origins.
ALLOWED_ORIGINS=http://localhost:3000

# Root log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Database connection string. Local default is a SQLite file; swap for a
# Postgres/Supabase URL in production. No real credentials belong in this file.
DATABASE_URL=sqlite:///./hirelens.db
